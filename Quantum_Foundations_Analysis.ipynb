    "def linear_model(x, intercept, slope):\n",
    "    return intercept + slope * x\n",
    "\n",
    "# Data from Experiment 6 (Table 3 in the paper)\n",
    "delays = np.array([0, 50, 100, 200])\n",
    "asymmetry = np.array([-4.50, -12.00, -25.50, -48.00])\n",
    "errors = np.array([5.20, 5.45, 5.80, 6.15])\n",
    "\n",
    "# Perform weighted least squares fit\n",
    "popt, pcov = curve_fit(linear_model, delays, asymmetry, sigma=errors, absolute_sigma=True)\n",
    "intercept, slope = popt\n",
    "intercept_err = np.sqrt(pcov[0,0])\n",
    "\n",
    "print(f\"Extrapolated Asymmetry (T=0): {intercept:.2f} ± {intercept_err:.2f} counts\")\n",
    "\n",
    "# Plotting the ZNE results\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.errorbar(delays, asymmetry, yerr=errors, fmt='o', label='Experimental Data', color='red')\n",
    "x_range = np.linspace(-10, 210, 100)\n",
    "plt.plot(x_range, linear_model(x_range, *popt), '--', label='ZNE Fit', color='blue')\n",
    "plt.axhline(0, color='black', alpha=0.3)\n",
    "plt.xlabel(\"Delay (ns)\")\n",
    "plt.ylabel(\"Asymmetry (counts)\")\n",
    "plt.title(\"Experiment 6: Zero-Noise Extrapolation\")\n",
    "plt.legend()\n",
    "plt.grid(True, alpha=0.2)\n",
